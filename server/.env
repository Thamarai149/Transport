NODE_ENV=development
PORT=5000

# Local MongoDB — connect via MongoDB Compass at mongodb://localhost:27017
# Compass URI: mongodb://localhost:27017/transponet
MONGO_URI=mongodb://localhost:27017/transponet

JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=30d

# AI service (Python FastAPI — run locally with: uvicorn main:app --reload)
AI_SERVICE_URL=http://localhost:8000
